# /etc/shadow - TomahawkOS password hashes
# Format: username:password_hash
#
# Currently the kernel stores password hashes in RAM via password_store.
# This file defines the on-disk layout for future VFS-backed authentication.
#
# Hash algorithm: SHA-256
# admin default password: 1234
# SHA256("1234") = 03ac674216f3e15c761ee1a5e255f067953623c8b388b4459e13f978d7c846f4
#
admin:03ac674216f3e15c761ee1a5e255f067953623c8b388b4459e13f978d7c846f4
guest:*

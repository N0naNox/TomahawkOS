# /etc/passwd - TomahawkOS user account database
# Format: username:x:uid:gid:comment:home:shell
#
# The 'x' in the password field means the hash is in /etc/shadow.
# UID 0 = root/admin privileges.
#
admin:x:0:0:System Administrator:/home/admin:/bin/shell
guest:x:65534:65534:Guest Account:/tmp:/bin/shell

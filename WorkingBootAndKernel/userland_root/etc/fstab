# /etc/fstab - TomahawkOS filesystem table
# Format: device  mountpoint  fstype  flags
#
# This file describes the desired mount hierarchy.
# The kernel reads this (future) or hard-codes mounts in fs_mount_system_dirs().
#
# device       mountpoint   fstype   flags
rootfs         /            ramfs    defaults
none           /tmp         ramfs    noexec
none           /dev         ramfs    noexec
